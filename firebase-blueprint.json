{
  "entities": {
    "Service": {
      "title": "Service",
      "description": "Prestations du coach sportif",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Titre du service" },
        "tagline": { "type": "string", "description": "Phrase d'accroche" },
        "description": { "type": "string", "description": "Description complète" },
        "icon": { "type": "string", "description": "Nom de l'icône Lucide" },
        "kanji": { "type": "string", "description": "Caractère japonais associé" },
        "price": { "type": "number", "description": "Prix du service" },
        "duration": { "type": "string", "description": "Durée du service (ex: 1h)" },
        "image": { "type": "string", "description": "URL de l'image" },
        "featured": { "type": "boolean", "description": "Si le service est mis en avant" },
        "order": { "type": "number", "description": "Ordre d'affichage" }
      },
      "required": ["title"]
    },
    "Reservation": {
      "title": "Reservation",
      "description": "Demandes de rendez-vous des clients",
      "type": "object",
      "properties": {
        "clientName": { "type": "string", "description": "Nom du client" },
        "serviceId": { "type": "string", "description": "ID du service réservé" },
        "serviceTitle": { "type": "string", "description": "Titre du service (pour historique)" },
        "date": { "type": "string", "format": "date", "description": "Date du rendez-vous" },
        "time": { "type": "string", "description": "Heure du rendez-vous" },
        "duration": { "type": "string", "description": "Durée prévue" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"], "description": "Statut de la réservation" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Date de création" }
      },
      "required": ["clientName", "serviceId", "date", "time", "status"]
    },
    "ContactRequest": {
      "title": "ContactRequest",
      "description": "Demandes de contact via le popup",
      "type": "object",
      "properties": {
        "firstName": { "type": "string", "description": "Prénom" },
        "lastName": { "type": "string", "description": "Nom" },
        "email": { "type": "string", "format": "email", "description": "Email de contact" },
        "message": { "type": "string", "description": "Message de la demande" },
        "desiredDate": { "type": "string", "format": "date", "description": "Date souhaitée" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Date de création" }
      },
      "required": ["firstName", "lastName", "message"]
    },
    "LeSaviezVous": {
      "title": "LeSaviezVous",
      "description": "Articles culture/santé rotatifs",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Titre de l'article" },
        "content": { "type": "string", "description": "Contenu (Markdown)" },
        "image": { "type": "string", "description": "URL de l'image optionnelle" },
        "active": { "type": "boolean", "description": "Si l'article est actif" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Date de publication" }
      },
      "required": ["title", "content", "active"]
    },
    "Verbatim": {
      "title": "Verbatim",
      "description": "Témoignages clients",
      "type": "object",
      "properties": {
        "author": { "type": "string", "description": "Auteur du témoignage" },
        "content": { "type": "string", "description": "Contenu du témoignage" },
        "rating": { "type": "number", "description": "Note (1-5)" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Date de création" }
      },
      "required": ["author", "content"]
    },
    "Media": {
      "title": "Media",
      "description": "Bibliothèque d'images uploadées",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Nom du fichier" },
        "url": { "type": "string", "description": "URL de l'image" },
        "type": { "type": "string", "description": "Type MIME" },
        "size": { "type": "number", "description": "Taille en octets" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Date d'upload" }
      },
      "required": ["name", "url"]
    }
  },
  "firestore": {
    "/services/{serviceId}": { "schema": "Service", "description": "Services proposés" },
    "/reservations/{reservationId}": { "schema": "Reservation", "description": "Réservations clients" },
    "/contact_requests/{requestId}": { "schema": "ContactRequest", "description": "Demandes de contact" },
    "/le_saviez_vous/{articleId}": { "schema": "LeSaviezVous", "description": "Articles rotatifs" },
    "/verbatims/{verbatimId}": { "schema": "Verbatim", "description": "Témoignages" },
    "/media_library/{mediaId}": { "schema": "Media", "description": "Galerie média" }
  }
}
